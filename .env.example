# Copy this file to .env and fill in your real values. Never commit .env to git.

PORT=4000

# Get these from https://dashboard.razorpay.com/app/keys
# Start with TEST keys while building, switch to LIVE keys only when ready to accept real payments.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
